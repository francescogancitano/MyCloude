###################################################################################################
#                           [JWT AUTENTIFICATION ENVIRONMENT VARIABLES]                           #
###################################################################################################

#RUN "openssl rand -hex 32" TO CREATE YOUR OWN SECRET KEY
#I've generated one for you

SECRET_KEY="1a22c4c98466f5a34dc7627859d54ad85a8a999be227e71698cbe9a13f053e55" #DEFAULT ONE, CHANGE IT BY RUNNING 'openssl rand -hex 32'
#algorithm to sign the criptography
ALGORITHM="HS256"
#how much time for the token to expire
ACCESS_TOKEN_EXPIRE_MINUTES="15"

###################################################################################################
